        const emojis = ['🫘', '☕', '🥛', '🌱', '🧁', '🍂', '🤎'];
        function spawnCoffeeElement(event) {
            const zone = document.getElementById('interactive-zone');
            const rect = zone.getBoundingClientRect();
            const x = event.clientX - rect.left;
            const y = event.clientY - rect.top;

            const randomEmoji = emojis[Math.floor(Math.random() * emojis.length)];
            
            const newItem = document.createElement('div');
            newItem.innerText = randomEmoji;
            newItem.className = 'absolute text-4xl select-none cursor-pointer interactive-bean';
            newItem.style.left = `${x - 20}px`;
            newItem.style.top = `${y - 20}px`;
            newItem.style.transition = 'all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
            
            const randomRotation = Math.random() * 360;
            newItem.style.transform = `scale(0) rotate(${randomRotation}deg)`;

            zone.appendChild(newItem);

            setTimeout(() => {
                newItem.style.transform = `scale(1) rotate(${randomRotation + 20}deg)`;
            }, 50);

            newItem.onclick = (e) => {
                e.stopPropagation();
                newItem.style.transform = 'scale(0) translateY(-50px)';
                newItem.style.opacity = '0';
                setTimeout(() => newItem.remove(), 500);
            };
        }

        function shakeAllElements() {
            const elements = document.querySelectorAll('.interactive-bean');
            elements.forEach(el => {
                const randomX = (Math.random() - 0.5) * 60;
                const randomY = (Math.random() - 0.5) * 60;
                const randomRot = (Math.random() - 0.5) * 90;
                
                el.style.transform = `translate(${randomX}px, ${randomY}px) rotate(${randomRot}deg) scale(1.2)`;
                
                setTimeout(() => {
                    el.style.transform = '';
                }, 800);
            });
        }
